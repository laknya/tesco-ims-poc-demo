{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "MigrationPipelineElevatedTesting",
      "Effect": "Allow",
      "Action": [
        "cloudformation:*",
        "ec2:*",
        "kms:*",
        "s3:*"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": "eu-west-1"
        }
      }
    },
    {
      "Sid": "GlobalReadOnlyHelpers",
      "Effect": "Allow",
      "Action": [
        "sts:GetCallerIdentity",
        "iam:GetRole",
        "iam:ListRolePolicies",
        "iam:GetRolePolicy"
      ],
      "Resource": "*"
    }
  ]
}
